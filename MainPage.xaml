<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:PianoApp.Services"
             x:Class="PianoApp.MainPage"
             Title="PianoSing App — 5 octaves"
             BackgroundColor="#1a1a2e">
    <Grid RowDefinitions="Auto,*" Padding="8">
        <Label Grid.Row="0" Text="Swipe sideways for the full keyboard. Tap keys or use keyboard: 1–6 = octave, then A W S E D F T G Y H U J. NoteMapping.json links notes to audio."
               TextColor="#eeeeee" FontSize="12" Margin="0,6" LineBreakMode="WordWrap" />
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Always"
                    VerticalScrollBarVisibility="Never"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">
            <GraphicsView x:Name="PianoCanvas"
                          BackgroundColor="#16213e"
                          HeightRequest="220"
                          HorizontalOptions="Start"
                          VerticalOptions="Start"
                          StartInteraction="OnStartInteraction"
                          EndInteraction="OnEndInteraction" />
        </ScrollView>
    </Grid>
</ContentPage>
